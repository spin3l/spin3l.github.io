---
import LanguagePicker from "@/components/LanguagePicker.astro";
import ThemePicker from "@/components/ThemePicker.astro";
import { ui } from "@/i18n/ui";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import CvDownload from "./CvDownload.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

type NavItem = {
  title: keyof typeof ui.en;
  label: keyof typeof ui.en;
  url?: string;
};

const navItems: Array<NavItem> = [
  { title: "nav.experience", label: "nav.experience" },
  { title: "nav.projects", label: "nav.projects" },
  { title: "nav.open-source", label: "nav.open-source" },
  {
    title: "nav.contact",
    label: "nav.contact",
    url: "mailto:dev.christianlopezgarcia@gmail.com",
  },
];
---

<header
  class="top-0 z-50 fixed flex md:flex-row flex-col justify-center items-center gap-2 mx-auto mt-2 md:mt-3 px-4 w-full"
>
  <!-- Main Nav Bar Capsule -->
  <nav
    class="flex flex-wrap justify-center items-center gap-x-4 gap-y-1 px-4 py-1 md:py-0 rounded-full w-fit max-w-[calc(100vw-2rem)] font-medium text-gray-600 dark:text-gray-200 text-xs sm:text-sm"
  >
    {
      navItems.map(({ label, url, title }) => (
        <a
          class="block relative py-1.5 md:py-2 hover:text-blue-500 dark:hover:text-yellow-400 whitespace-nowrap transition-colors duration-300"
          aria-label={t(label)}
          href={url ?? `#/${t(label)}`}
        >
          {t(title)}
        </a>
      ))
    }

    <!-- CV Button wrapped or adjusted cleanly -->
    <div class="py-1 md:py-0 shrink-0">
      <CvDownload class="scale-90 sm:scale-100" />
    </div>
  </nav>

  <!-- Right Utility Dock Capsule -->
  <div
    id="utility-dock"
    class="flex justify-center items-center gap-x-3 md:gap-x-4 px-4 py-1.5 md:py-0 rounded-full shrink-0"
  >
    <LanguagePicker />
    <ThemePicker
      class="text-gray-600 hover:text-blue-500 dark:hover:text-yellow-400 dark:text-gray-200 transition-colors"
    />
  </div>
</header>

<script>
  // Your existing IntersectionObserver logic remains pristine
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section");
    const navItems = document.querySelectorAll("header nav a");

    const callback = (entries: any[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            if (item.getAttribute("aria-label") == entry.target.id) {
              item.classList.add("text-blue-500");
            } else {
              item.classList.remove("text-blue-500");
            }
          });
        }
      });
    };

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    });

    sections.forEach((section) => {
      observer.observe(section);
    });

    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect();
      } else {
        sections.forEach((section) => {
          observer.observe(section);
        });
      }
    };
  });
</script>

<style>
  /* Attach the scroll timeline animation to both elements */
  nav,
  #utility-dock {
    animation: header-dock-scroll 1s linear both;
    animation-timeline: scroll();
    animation-range: 0 80px;
  }

  /* Theme-dependent style states using modern CSS variables / nesting */
  @keyframes header-dock-scroll {
    0% {
      background-color: transparent;
      box-shadow: none;
      border: 1px solid transparent;
      backdrop-filter: blur(0px);
    }
    100% {
      background-color: rgba(255, 255, 255, 0.75);
      border: 1px solid rgba(0, 0, 0, 0.06);
      box-shadow: 0 4px 20px -2px rgba(0, 0, 0, 0.05);
      backdrop-filter: blur(12px);
    }
  }

  /* Override structural colors elegantly for Tailwind dark mode classes */
  :global(.dark) nav,
  :global(.dark) #utility-dock {
    animation-name: header-dock-scroll-dark;
  }

  @keyframes header-dock-scroll-dark {
    0% {
      background-color: transparent;
      box-shadow: none;
      border: 1px solid transparent;
      backdrop-filter: blur(0px);
    }
    100% {
      background-color: rgba(17, 24, 39, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.4);
      backdrop-filter: blur(12px);
    }
  }
</style>
