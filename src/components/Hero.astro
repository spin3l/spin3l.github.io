---
import Email from "./Email.astro";
import GitHubIcon from "./icons/GitHubIcon.astro";
import LinkedInIcon from "./icons/LinkedInIcon.astro";
import SocialPill from "./icons/SocialPill.astro";
---

<div class="flex gap-8 mb-4">
  <img
    class="shadow-md shadow-white mb-2 lg:mb-4 rounded-full size-24 -4"
    src="udl.jpeg"
    alt="spin3l photo"
  /><a
    class="flex justify-center items-center"
    href="https://www.linkedin.com/in/christian-lopez-garcia02/"
    target="_blank"
    rel="noopener"
  >
  </a>
</div>
<h1
  class="inline-block gap-x-4 pb-6 lg:pb-10 text-white text-2xl lg:text-4xl col"
>
  Hey, soy <span class="font-semibold text-purple-200/90"
    >Christian López García</span
  >
</h1>
<h2 class="max-w-[700px] text-xl lg:text-2xl text-pretty">
  <span class="text-yellow-200/90"> Desarrollador Full-Stack</span> de
  <span class="text-red-200/90">Lleida, España</span>.
  <span class="opacity-85">Especializado en crear aplicaciones con React.</span>
</h2>

<div class="flex flex-col gap-8">
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="https://www.linkedin.com/in/christian-lopez-garcia02/">
      <LinkedInIcon class="size-6" />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://github.com/spin3l">
      <GitHubIcon class="size-6" />
      GitHub
    </SocialPill>
  </nav>
  <Email />
</div>
